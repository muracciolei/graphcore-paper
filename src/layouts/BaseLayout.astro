---
// src/layouts/BaseLayout.astro
const { title } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="navbar">
      <div class="nav-inner">
        <a href="#" class="nav-logo">GraphCore[v0.1]</a>
        <button class="nav-toggle" aria-label="Toggle navigation">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <ul class="nav-links">
          <li><a href="#abstract">Abstract</a></li>
          <li><a href="#assumptions">Assumptions</a></li>
          <li><a href="#multi-state-logic">Logic Model</a></li>
          <li><a href="#continuous-signal">Signal Flow</a></li>
          <li><a href="#architecture">Architecture</a></li>
          <li><a href="#execution">Execution</a></li>
          <li><a href="#memory">Memory</a></li>
          <li><a href="#programming">Programming</a></li>
          <li><a href="#limitations">Limitations</a></li>
          <li><a href="#references">References</a></li>
        </ul>
      </div>
    </nav>

    <header class="site-header">
      <h1 class="header-title">GraphCore</h1>
      <p class="header-subtitle">A Programmable Photonic Graphene Processor</p>
      
      <div class="metadata-block">
        <p><strong>Status:</strong> Conceptual Architecture Proposal</p>
        <p><strong>Version:</strong> 0.1 &mdash; Foundational Model</p>
        <p><strong>Author:</strong> Ivan Muracciole</p>
        <p><strong>Date:</strong> March 2026</p>
      </div>

      <div class="spectrum-bar mt-6"></div>
    </header>

    <main class="content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <p class="footer-text">GraphCore Concept Paper</p>
        <p class="footer-muted">Version 0.1 &mdash; Foundational Model</p>
        <p class="footer-muted">Ivan Muracciole &mdash; 2026</p>
      </div>
    </footer>

    <style>
      /* ========== RESET & BASE ========== */
      *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
        scroll-padding-top: 5rem;
      }

      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background-color: #05080e;
        color: #d4dae6;
        line-height: 1.8;
        font-size: 16px;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        background-image:
          linear-gradient(rgba(30, 41, 59, 0.4) 1px, transparent 1px),
          linear-gradient(90deg, rgba(30, 41, 59, 0.4) 1px, transparent 1px);
        background-size: 30px 30px;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      body::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, #4B0082, #0000FF, #00FFFF, #00FF00, #FFFF00, #FF7F00, #FF0000);
        z-index: 9999;
      }

      ::selection {
        background: rgba(148, 163, 184, 0.35);
        color: #ffffff;
      }

      /* ========== NAVIGATION ========== */
      .navbar {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(5, 8, 14, 0.95);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid #1e293b;
      }

      .nav-inner {
        max-width: 960px;
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        min-height: 3.25rem;
        flex-wrap: wrap;
      }

      .nav-logo {
        font-family: 'JetBrains Mono', monospace;
        font-weight: 700;
        font-size: 1.1rem;
        color: #cbd5e1;
        text-decoration: none;
        letter-spacing: -0.02em;
        padding: 0.75rem 0;
      }

      .nav-toggle {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        flex-direction: column;
        gap: 5px;
      }

      .nav-toggle span {
        display: block;
        width: 22px;
        height: 2px;
        background: #94a3b8;
        border-radius: 2px;
      }

      .nav-links {
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem;
        padding: 0.5rem 0;
      }

      .nav-links a {
        display: block;
        padding: 0.35rem 0.6rem;
        color: #64748b;
        text-decoration: none;
        font-size: 0.78rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        font-family: 'JetBrains Mono', monospace;
        transition: color 0.2s;
      }

      .nav-links a:hover {
        color: #cbd5e1;
      }

      /* ========== HEADER ========== */
      .site-header {
        position: relative;
        text-align: left;
        max-width: 960px;
        margin: 0 auto;
        padding: 5rem 1.5rem 3rem;
        width: 100%;
      }

      .header-title {
        font-family: 'JetBrains Mono', monospace;
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin-bottom: 0.5rem;
      }

      .header-subtitle {
        font-family: 'JetBrains Mono', monospace;
        font-size: clamp(1rem, 2vw, 1.25rem);
        color: #94a3b8;
        font-weight: 400;
        margin-bottom: 2rem;
      }

      .metadata-block {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.85rem;
        color: #cbd5e1;
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid #1e293b;
        padding: 1.5rem;
        border-radius: 4px;
        max-width: 500px;
      }

      .metadata-block p {
        margin-bottom: 0.25rem;
      }

      .metadata-block strong {
        color: #64748b;
        width: 100px;
        display: inline-block;
      }

      .spectrum-bar {
        width: 100%;
        height: 1px;
        margin: 3rem 0 0;
        background: linear-gradient(90deg, #1e293b, #4B0082, #00FFFF, #00FF00, #FF0000, #1e293b);
        opacity: 0.5;
      }

      /* ========== CONTENT ========== */
      .content {
        max-width: 960px;
        margin: 0 auto;
        padding: 0 1.5rem 4rem;
        width: 100%;
        flex: 1;
      }

      /* ========== TYPOGRAPHY ========== */
      h1, h2, h3, h4 {
        color: #ffffff;
        font-weight: 600;
        line-height: 1.3;
        letter-spacing: -0.01em;
        font-family: 'JetBrains Mono', monospace;
      }

      h2 {
        font-size: clamp(1.25rem, 3vw, 1.6rem);
        margin-top: 3.5rem;
        margin-bottom: 1.5rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid #1e293b;
      }

      h3 {
        font-size: clamp(1.1rem, 2.5vw, 1.25rem);
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        color: #cbd5e1;
      }

      p {
        margin-bottom: 1.25rem;
      }

      strong {
        color: #e2e8f0;
        font-weight: 600;
      }

      em {
        color: #94a3b8;
        font-style: italic;
      }

      a {
        color: #cbd5e1;
        text-decoration: underline;
        text-decoration-color: #334155;
        text-underline-offset: 3px;
        transition: color 0.2s;
      }

      a:hover {
        color: #ffffff;
      }

      /* ========== LISTS ========== */
      ul, ol {
        margin-bottom: 1.5rem;
        padding-left: 1.5rem;
      }

      li {
        margin-bottom: 0.5rem;
      }

      ul li::marker {
        color: #64748b;
      }

      /* ========== BLOCKQUOTES ========== */
      blockquote {
        font-family: 'JetBrains Mono', monospace;
        border-left: 2px solid #334155;
        padding: 1.25rem 1.5rem;
        margin: 2rem 0;
        background: rgba(15, 23, 42, 0.4);
        color: #94a3b8;
        font-size: 0.9rem;
      }

      blockquote p:last-child {
        margin-bottom: 0;
      }

      .disclaimer-box {
        border-color: #7f1d1d;
        background: rgba(69, 10, 10, 0.1);
      }
      .disclaimer-box strong {
        color: #fca5a5;
      }

      /* ========== CODE ========== */
      code {
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
        font-size: 0.85em;
        background: rgba(30, 41, 59, 0.8);
        color: #cbd5e1;
        padding: 0.2em 0.4em;
        border-radius: 2px;
        border: 1px solid #1e293b;
      }

      pre {
        background: #0f172a;
        border: 1px solid #1e293b;
        border-radius: 4px;
        padding: 1.25rem 1.5rem;
        margin: 1.5rem 0;
        overflow-x: auto;
        line-height: 1.6;
      }

      pre code {
        background: none;
        border: none;
        padding: 0;
        color: #94a3b8;
      }

      /* ========== TABLES ========== */
      table {
        width: 100%;
        border-collapse: collapse;
        margin: 2rem 0;
        font-size: 0.85rem;
        font-family: 'JetBrains Mono', monospace;
      }

      thead {
        background: #0f172a;
      }

      th {
        text-align: left;
        padding: 1rem;
        font-weight: 500;
        color: #94a3b8;
        border: 1px solid #1e293b;
      }

      td {
        padding: 1rem;
        border: 1px solid #1e293b;
        color: #cbd5e1;
      }

      tbody tr:hover {
        background: rgba(30, 41, 59, 0.4);
      }

      /* ========== FOOTER ========== */
      .site-footer {
        margin-top: auto;
        border-top: 1px solid #1e293b;
        background: #05080e;
        font-family: 'JetBrains Mono', monospace;
      }

      .footer-inner {
        max-width: 960px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }

      .footer-text {
        font-size: 0.85rem;
        color: #94a3b8;
        margin-bottom: 0.25rem;
      }

      .footer-muted {
        font-size: 0.75rem;
        color: #475569;
        margin-bottom: 0.15rem;
      }

      /* ========== RESPONSIVE ========== */
      @media (max-width: 768px) {
        .nav-toggle {
          display: flex;
        }

        .nav-links {
          display: none;
          flex-direction: column;
          width: 100%;
          padding-bottom: 0.75rem;
          gap: 0;
        }

        .nav-links.open {
          display: flex;
        }
        
        table {
          display: block;
          overflow-x: auto;
        }
      }
    </style>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const toggle = document.querySelector('.nav-toggle');
        const links = document.querySelector('.nav-links');
        if (toggle && links) {
          toggle.addEventListener('click', () => {
            links.classList.toggle('open');
          });
        }
      });
    </script>
  </body>
</html>

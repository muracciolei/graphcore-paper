---
---

<div class="memory-diagram-container">
  <svg
    viewBox="0 0 800 500"
    xmlns="http://www.w3.org/2000/svg"
    class="memory-diagram"
    role="img"
    aria-label="GraphCore Unified Memory Architecture Diagram"
  >
    <defs>
      <!-- Glow filters -->
      <filter id="glow-cyan" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="4" result="blur" />
        <feFlood flood-color="#38bdf8" flood-opacity="0.6" result="color" />
        <feComposite in="color" in2="blur" operator="in" result="glow" />
        <feMerge>
          <feMergeNode in="glow" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
      <filter id="glow-indigo" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="4" result="blur" />
        <feFlood flood-color="#6366f1" flood-opacity="0.6" result="color" />
        <feComposite in="color" in2="blur" operator="in" result="glow" />
        <feMerge>
          <feMergeNode in="glow" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
      <filter id="glow-violet" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="4" result="blur" />
        <feFlood flood-color="#a78bfa" flood-opacity="0.6" result="color" />
        <feComposite in="color" in2="blur" operator="in" result="glow" />
        <feMerge>
          <feMergeNode in="glow" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
      <filter id="glow-bright" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="6" result="blur" />
        <feFlood flood-color="#22d3ee" flood-opacity="0.5" result="color" />
        <feComposite in="color" in2="blur" operator="in" result="glow" />
        <feMerge>
          <feMergeNode in="glow" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
      <filter id="glow-subtle" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="3" result="blur" />
        <feFlood flood-color="#22d3ee" flood-opacity="0.3" result="color" />
        <feComposite in="color" in2="blur" operator="in" result="glow" />
        <feMerge>
          <feMergeNode in="glow" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>

      <!-- Photon flow gradient -->
      <linearGradient id="photon-flow-1" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#38bdf8" stop-opacity="0" />
        <stop offset="30%" stop-color="#38bdf8" stop-opacity="0.8" />
        <stop offset="70%" stop-color="#22d3ee" stop-opacity="0.9" />
        <stop offset="100%" stop-color="#22d3ee" stop-opacity="0" />
      </linearGradient>
      <linearGradient id="photon-flow-2" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#6366f1" stop-opacity="0" />
        <stop offset="30%" stop-color="#6366f1" stop-opacity="0.7" />
        <stop offset="70%" stop-color="#a78bfa" stop-opacity="0.8" />
        <stop offset="100%" stop-color="#a78bfa" stop-opacity="0" />
      </linearGradient>
      <linearGradient id="photon-flow-3" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#a78bfa" stop-opacity="0" />
        <stop offset="30%" stop-color="#a78bfa" stop-opacity="0.7" />
        <stop offset="70%" stop-color="#38bdf8" stop-opacity="0.8" />
        <stop offset="100%" stop-color="#38bdf8" stop-opacity="0" />
      </linearGradient>

      <!-- Radial gradient for substrate -->
      <radialGradient id="substrate-gradient" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#22d3ee" stop-opacity="0.15" />
        <stop offset="60%" stop-color="#6366f1" stop-opacity="0.08" />
        <stop offset="100%" stop-color="#0a0e17" stop-opacity="0" />
      </radialGradient>

      <!-- Animated dash pattern -->
      <pattern id="photon-dots" x="0" y="0" width="12" height="12" patternUnits="userSpaceOnUse">
        <circle cx="3" cy="3" r="1.2" fill="#22d3ee" opacity="0.7">
          <animate attributeName="opacity" values="0.3;0.9;0.3" dur="2s" repeatCount="indefinite" />
        </circle>
        <circle cx="9" cy="9" r="0.8" fill="#38bdf8" opacity="0.5">
          <animate attributeName="opacity" values="0.5;1;0.5" dur="1.5s" repeatCount="indefinite" />
        </circle>
      </pattern>
    </defs>

    <!-- Background -->
    <rect width="800" height="500" fill="#0a0e17" />

    <!-- Subtle grid pattern -->
    <g opacity="0.08">
      <line x1="0" y1="100" x2="800" y2="100" stroke="#38bdf8" stroke-width="0.5" />
      <line x1="0" y1="200" x2="800" y2="200" stroke="#38bdf8" stroke-width="0.5" />
      <line x1="0" y1="300" x2="800" y2="300" stroke="#38bdf8" stroke-width="0.5" />
      <line x1="0" y1="400" x2="800" y2="400" stroke="#38bdf8" stroke-width="0.5" />
      <line x1="100" y1="0" x2="100" y2="500" stroke="#38bdf8" stroke-width="0.5" />
      <line x1="200" y1="0" x2="200" y2="500" stroke="#38bdf8" stroke-width="0.5" />
      <line x1="300" y1="0" x2="300" y2="500" stroke="#38bdf8" stroke-width="0.5" />
      <line x1="400" y1="0" x2="400" y2="500" stroke="#38bdf8" stroke-width="0.5" />
      <line x1="500" y1="0" x2="500" y2="500" stroke="#38bdf8" stroke-width="0.5" />
      <line x1="600" y1="0" x2="600" y2="500" stroke="#38bdf8" stroke-width="0.5" />
      <line x1="700" y1="0" x2="700" y2="500" stroke="#38bdf8" stroke-width="0.5" />
    </g>

    <!-- ============================================ -->
    <!-- UNIFIED ARCHITECTURE (Left Half)             -->
    <!-- ============================================ -->
    <g transform="translate(280, 250)">

      <!-- Graphene Substrate - radial glow -->
      <circle cx="0" cy="0" r="180" fill="url(#substrate-gradient)" />
      <circle cx="0" cy="0" r="180" fill="none" stroke="#22d3ee" stroke-width="0.5" stroke-dasharray="4 8" opacity="0.3">
        <animate attributeName="stroke-dashoffset" from="0" to="24" dur="3s" repeatCount="indefinite" />
      </circle>

      <!-- Outer Ring: Storage Layer -->
      <circle cx="0" cy="0" r="160" fill="none" stroke="#a78bfa" stroke-width="2.5" opacity="0.9" filter="url(#glow-violet)" />
      <circle cx="0" cy="0" r="158" fill="none" stroke="#a78bfa" stroke-width="0.5" opacity="0.3" />
      <circle cx="0" cy="0" r="162" fill="none" stroke="#a78bfa" stroke-width="0.5" opacity="0.3" />
      <!-- Storage ring fill -->
      <circle cx="0" cy="0" r="160" fill="#a78bfa" opacity="0.03" />

      <!-- Middle Ring: Memory Layer -->
      <circle cx="0" cy="0" r="110" fill="none" stroke="#6366f1" stroke-width="2.5" opacity="0.9" filter="url(#glow-indigo)" />
      <circle cx="0" cy="0" r="108" fill="none" stroke="#6366f1" stroke-width="0.5" opacity="0.3" />
      <circle cx="0" cy="0" r="112" fill="none" stroke="#6366f1" stroke-width="0.5" opacity="0.3" />
      <!-- Memory ring fill -->
      <circle cx="0" cy="0" r="110" fill="#6366f1" opacity="0.04" />

      <!-- Inner Ring: Processing Layer -->
      <circle cx="0" cy="0" r="60" fill="none" stroke="#38bdf8" stroke-width="2.5" opacity="0.9" filter="url(#glow-cyan)" />
      <circle cx="0" cy="0" r="58" fill="none" stroke="#38bdf8" stroke-width="0.5" opacity="0.3" />
      <circle cx="0" cy="0" r="62" fill="none" stroke="#38bdf8" stroke-width="0.5" opacity="0.3" />
      <!-- Processing ring fill -->
      <circle cx="0" cy="0" r="60" fill="#38bdf8" opacity="0.06" />

      <!-- Center core -->
      <circle cx="0" cy="0" r="8" fill="#22d3ee" opacity="0.8" filter="url(#glow-bright)">
        <animate attributeName="r" values="6;10;6" dur="3s" repeatCount="indefinite" />
        <animate attributeName="opacity" values="0.6;1;0.6" dur="3s" repeatCount="indefinite" />
      </circle>

      <!-- Photon flows: Processing <-> Memory -->
      <g opacity="0.7">
        <!-- Flow up -->
        <line x1="0" y1="-60" x2="0" y2="-110" stroke="url(#photon-flow-1)" stroke-width="1.5">
          <animate attributeName="stroke-dashoffset" from="20" to="0" dur="1s" repeatCount="indefinite" />
        </line>
        <line x1="0" y1="-60" x2="0" y2="-110" stroke="#38bdf8" stroke-width="1" stroke-dasharray="3 7" opacity="0.8">
          <animate attributeName="stroke-dashoffset" from="10" to="0" dur="0.8s" repeatCount="indefinite" />
        </line>
        <!-- Flow down -->
        <line x1="0" y1="60" x2="0" y2="110" stroke="url(#photon-flow-1)" stroke-width="1.5">
          <animate attributeName="stroke-dashoffset" from="0" to="20" dur="1s" repeatCount="indefinite" />
        </line>
        <line x1="0" y1="60" x2="0" y2="110" stroke="#38bdf8" stroke-width="1" stroke-dasharray="3 7" opacity="0.8">
          <animate attributeName="stroke-dashoffset" from="0" to="10" dur="0.8s" repeatCount="indefinite" />
        </line>
        <!-- Flow right -->
        <line x1="60" y1="0" x2="110" y2="0" stroke="url(#photon-flow-1)" stroke-width="1.5">
          <animate attributeName="stroke-dashoffset" from="0" to="20" dur="1s" repeatCount="indefinite" />
        </line>
        <!-- Flow left -->
        <line x1="-60" y1="0" x2="-110" y2="0" stroke="url(#photon-flow-1)" stroke-width="1.5">
          <animate attributeName="stroke-dashoffset" from="20" to="0" dur="1s" repeatCount="indefinite" />
        </line>
        <!-- Diagonal flows -->
        <line x1="42" y1="-42" x2="78" y2="-78" stroke="#22d3ee" stroke-width="0.8" stroke-dasharray="2 6" opacity="0.6">
          <animate attributeName="stroke-dashoffset" from="8" to="0" dur="1.2s" repeatCount="indefinite" />
        </line>
        <line x1="-42" y1="42" x2="-78" y2="78" stroke="#22d3ee" stroke-width="0.8" stroke-dasharray="2 6" opacity="0.6">
          <animate attributeName="stroke-dashoffset" from="0" to="8" dur="1.2s" repeatCount="indefinite" />
        </line>
      </g>

      <!-- Photon flows: Memory <-> Storage -->
      <g opacity="0.6">
        <line x1="0" y1="-110" x2="0" y2="-160" stroke="url(#photon-flow-2)" stroke-width="1.5">
          <animate attributeName="stroke-dashoffset" from="20" to="0" dur="1.2s" repeatCount="indefinite" />
        </line>
        <line x1="0" y1="-110" x2="0" y2="-160" stroke="#6366f1" stroke-width="1" stroke-dasharray="3 7" opacity="0.7">
          <animate attributeName="stroke-dashoffset" from="10" to="0" dur="1s" repeatCount="indefinite" />
        </line>
        <line x1="0" y1="110" x2="0" y2="160" stroke="url(#photon-flow-2)" stroke-width="1.5">
          <animate attributeName="stroke-dashoffset" from="0" to="20" dur="1.2s" repeatCount="indefinite" />
        </line>
        <line x1="110" y1="0" x2="160" y2="0" stroke="url(#photon-flow-2)" stroke-width="1.5">
          <animate attributeName="stroke-dashoffset" from="0" to="20" dur="1.2s" repeatCount="indefinite" />
        </line>
        <line x1="-110" y1="0" x2="-160" y2="0" stroke="url(#photon-flow-2)" stroke-width="1.5">
          <animate attributeName="stroke-dashoffset" from="20" to="0" dur="1.2s" repeatCount="indefinite" />
        </line>
        <line x1="78" y1="-78" x2="113" y2="-113" stroke="#a78bfa" stroke-width="0.8" stroke-dasharray="2 6" opacity="0.5">
          <animate attributeName="stroke-dashoffset" from="8" to="0" dur="1.4s" repeatCount="indefinite" />
        </line>
        <line x1="-78" y1="78" x2="-113" y2="113" stroke="#a78bfa" stroke-width="0.8" stroke-dasharray="2 6" opacity="0.5">
          <animate attributeName="stroke-dashoffset" from="0" to="8" dur="1.4s" repeatCount="indefinite" />
        </line>
      </g>

      <!-- Photon flows: Processing <-> Storage (direct, no barrier) -->
      <g opacity="0.4">
        <line x1="42" y1="-42" x2="113" y2="-113" stroke="#22d3ee" stroke-width="0.6" stroke-dasharray="1 8" opacity="0.4">
          <animate attributeName="stroke-dashoffset" from="9" to="0" dur="1.8s" repeatCount="indefinite" />
        </line>
        <line x1="-42" y1="42" x2="-113" y2="113" stroke="#22d3ee" stroke-width="0.6" stroke-dasharray="1 8" opacity="0.4">
          <animate attributeName="stroke-dashoffset" from="0" to="9" dur="1.8s" repeatCount="indefinite" />
        </line>
      </g>

      <!-- Photon particles -->
      <g>
        <circle r="2.5" fill="#22d3ee" opacity="0.9" filter="url(#glow-bright)">
          <animateMotion dur="2s" repeatCount="indefinite" path="M0,-60 L0,-110" />
          <animate attributeName="opacity" values="0;0.9;0" dur="2s" repeatCount="indefinite" />
        </circle>
        <circle r="2" fill="#38bdf8" opacity="0.8">
          <animateMotion dur="2s" repeatCount="indefinite" path="M0,-110 L0,-60" begin="1s" />
          <animate attributeName="opacity" values="0;0.8;0" dur="2s" repeatCount="indefinite" begin="1s" />
        </circle>
        <circle r="2.5" fill="#6366f1" opacity="0.8" filter="url(#glow-indigo)">
          <animateMotion dur="2.5s" repeatCount="indefinite" path="M0,-110 L0,-160" />
          <animate attributeName="opacity" values="0;0.8;0" dur="2.5s" repeatCount="indefinite" />
        </circle>
        <circle r="2" fill="#a78bfa" opacity="0.7">
          <animateMotion dur="2.5s" repeatCount="indefinite" path="M0,-160 L0,-110" begin="1.25s" />
          <animate attributeName="opacity" values="0;0.7;0" dur="2.5s" repeatCount="indefinite" begin="1.25s" />
        </circle>
        <!-- Radial particle -->
        <circle r="1.5" fill="#22d3ee" opacity="0.6">
          <animateMotion dur="3s" repeatCount="indefinite" path="M60,0 L160,0" />
          <animate attributeName="opacity" values="0;0.6;0" dur="3s" repeatCount="indefinite" />
        </circle>
      </g>

      <!-- Labels -->
      <text x="0" y="-5" text-anchor="middle" fill="#38bdf8" font-family="'JetBrains Mono', 'Fira Code', 'SF Mono', monospace" font-size="9" font-weight="bold" letter-spacing="1" filter="url(#glow-cyan)">PROCESSING</text>
      <text x="0" y="7" text-anchor="middle" fill="#38bdf8" font-family="'JetBrains Mono', 'Fira Code', 'SF Mono', monospace" font-size="7" opacity="0.7" letter-spacing="0.5">LAYER</text>

      <text x="0" y="-85" text-anchor="middle" fill="#6366f1" font-family="'JetBrains Mono', 'Fira Code', 'SF Mono', monospace" font-size="8" font-weight="bold" letter-spacing="1" opacity="0.9">MEMORY LAYER</text>
      <text x="118" y="5" text-anchor="start" fill="#6366f1" font-family="'JetBrains Mono', 'Fira Code', 'SF Mono', monospace" font-size="7" opacity="0.6" letter-spacing="0.5">SRAM</text>

      <text x="0" y="-140" text-anchor="middle" fill="#a78bfa" font-family="'JetBrains Mono', 'Fira Code', 'SF Mono', monospace" font-size="8" font-weight="bold" letter-spacing="1" opacity="0.9">STORAGE LAYER</text>
      <text x="168" y="5" text-anchor="start" fill="#a78bfa" font-family="'JetBrains Mono', 'Fira Code', 'SF Mono', monospace" font-size="7" opacity="0.6" letter-spacing="0.5">DRAM</text>

      <!-- Graphene Substrate label -->
      <text x="0" y="185" text-anchor="middle" fill="#22d3ee" font-family="'JetBrains Mono', 'Fira Code', 'SF Mono', monospace" font-size="9" font-weight="bold" letter-spacing="1.5" opacity="0.8" filter="url(#glow-subtle)">GRAPHENE SUBSTRATE</text>

      <!-- Bidirectional arrows annotation -->
      <g transform="translate(135, -90)" opacity="0.7">
        <line x1="0" y1="0" x2="20" y2="-12" stroke="#22d3ee" stroke-width="1" />
        <polygon points="20,-15 20,-9 26,-12" fill="#22d3ee" />
        <line x1="20" y1="0" x2="0" y2="-12" stroke="#22d3ee" stroke-width="1" />
        <polygon points="0,-15 0,-9 -6,-12" fill="#22d3ee" />
      </g>
    </g>

    <!-- ============================================ -->
    <!-- DIVIDER: NO BARRIER                          -->
    <!-- ============================================ -->
    <g transform="translate(400, 250)">
      <!-- Vertical dashed divider -->
      <line x1="0" y1="-195" x2="0" y2="195" stroke="#22d3ee" stroke-width="1" stroke-dasharray="6 4" opacity="0.4">
        <animate attributeName="stroke-dashoffset" from="10" to="0" dur="2s" repeatCount="indefinite" />
      </line>

      <!-- NO SEPARATION label -->
      <rect x="-52" y="-8" width="104" height="16" rx="3" fill="#0a0e17" stroke="#22d3ee" stroke-width="1" opacity="0.9" />
      <text x="0" y="3" text-anchor="middle" fill="#22d3ee" font-family="'JetBrains Mono', 'Fira Code', 'SF Mono', monospace" font-size="7" font-weight="bold" letter-spacing="1" opacity="0.9">NO BARRIER</text>

      <!-- Photon crossing the divider -->
      <circle r="3" fill="#22d3ee" opacity="0.9" filter="url(#glow-bright)">
        <animate attributeName="cx" values="-30;30;-30" dur="3s" repeatCount="indefinite" />
        <animate attributeName="cy" values="0;0;0" dur="3s" repeatCount="indefinite" />
        <animate attributeName="opacity" values="0;1;0" dur="3s" repeatCount="indefinite" />
      </circle>
    </g>

    <!-- ============================================ -->
    <!-- TRADITIONAL ARCHITECTURE (Right Half)        -->
    <!-- ============================================ -->
    <g transform="translate(560, 250)">

      <!-- Traditional: Isolated boxes -->
      <!-- CPU/Processing box -->
      <rect x="-80" y="-170" width="160" height="90" rx="6" fill="none" stroke="#ef4444" stroke-width="1.5" opacity="0.5" stroke-dasharray="6 3" />
      <rect x="-80" y="-170" width="160" height="90" rx="6" fill="#ef4444" opacity="0.04" />
      <text x="0" y="-125" text-anchor="middle" fill="#ef4444" font-family="'JetBrains Mono', 'Fira Code', 'SF Mono', monospace" font-size="9" font-weight="bold" letter-spacing="1" opacity="0.7">CPU</text>
      <text x="0" y="-112" text-anchor="middle" fill="#ef4444" font-family="'JetBrains Mono', 'Fira Code', 'SF Mono', monospace" font-size="7" opacity="0.5" letter-spacing="0.5">PROCESSING</text>

      <!-- Divider: CPU <-> Memory -->
      <line x1="-60" y1="-75" x2="60" y2="-75" stroke="#ef4444" stroke-width="2" opacity="0.4" />
      <text x="70" y="-71" fill="#ef4444" font-family="'JetBrains Mono', 'Fira Code', 'SF Mono', monospace" font-size="6" opacity="0.5" letter-spacing="0.5">BUS</text>
      <!-- Bottleneck arrows -->
      <line x1="0" y1="-80" x2="0" y2="-70" stroke="#ef4444" stroke-width="1" opacity="0.5" />
      <polygon points="-3,-70 3,-70 0,-64" fill="#ef4444" opacity="0.5" />
      <line x1="10" y1="-70" x2="10" y2="-80" stroke="#ef4444" stroke-width="1" opacity="0.5" />
      <polygon points="7,-80 13,-80 10,-86" fill="#ef4444" opacity="0.5" />

      <!-- Memory box -->
      <rect x="-80" y="-65" width="160" height="90" rx="6" fill="none" stroke="#f59e0b" stroke-width="1.5" opacity="0.5" stroke-dasharray="6 3" />
      <rect x="-80" y="-65" width="160" height="90" rx="6" fill="#f59e0b" opacity="0.04" />
      <text x="0" y="-20" text-anchor="middle" fill="#f59e0b" font-family="'JetBrains Mono', 'Fira Code', 'SF Mono', monospace" font-size="9" font-weight="bold" letter-spacing="1" opacity="0.7">DRAM</text>
      <text x="0" y="-7" text-anchor="middle" fill="#f59e0b" font-family="'JetBrains Mono', 'Fira Code', 'SF Mono', monospace" font-size="7" opacity="0.5" letter-spacing="0.5">MEMORY</text>

      <!-- Divider: Memory <-> Storage -->
      <line x1="-60" y1="30" x2="60" y2="30" stroke="#f59e0b" stroke-width="2" opacity="0.4" />
      <text x="70" y="34" fill="#f59e0b" font-family="'JetBrains Mono', 'Fira Code', 'SF Mono', monospace" font-size="6" opacity="0.5" letter-spacing="0.5">I/O</text>
      <!-- Bottleneck arrows -->
      <line x1="0" y1="25" x2="0" y2="35" stroke="#f59e0b" stroke-width="1" opacity="0.5" />
      <polygon points="-3,35 3,35 0,41" fill="#f59e0b" opacity="0.5" />
      <line x1="10" y1="35" x2="10" y2="25" stroke="#f59e0b" stroke-width="1" opacity="0.5" />
      <polygon points="7,25 13,25 10,19" fill="#f59e0b" opacity="0.5" />

      <!-- Storage box -->
      <rect x="-80" y="40" width="160" height="90" rx="6" fill="none" stroke="#94a3b8" stroke-width="1.5" opacity="0.5" stroke-dasharray="6 3" />
      <rect x="-80" y="40" width="160" height="90" rx="6" fill="#94a3b8" opacity="0.04" />
      <text x="0" y="85" text-anchor="middle" fill="#94a3b8" font-family="'JetBrains Mono', 'Fira Code', 'SF Mono', monospace" font-size="9" font-weight="bold" letter-spacing="1" opacity="0.7">SSD / HDD</text>
      <text x="0" y="98" text-anchor="middle" fill="#94a3b8" font-family="'JetBrains Mono', 'Fira Code', 'SF Mono', monospace" font-size="7" opacity="0.5" letter-spacing="0.5">STORAGE</text>

      <!-- X marks on traditional arrows to indicate blockage -->
      <g opacity="0.4">
        <line x1="-5" y1="-78" x2="5" y2="-72" stroke="#ef4444" stroke-width="1.5" />
        <line x1="5" y1="-78" x2="-5" y2="-72" stroke="#ef4444" stroke-width="1.5" />
        <line x1="-5" y1="27" x2="5" y2="33" stroke="#f59e0b" stroke-width="1.5" />
        <line x1="5" y1="27" x2="-5" y2="33" stroke="#f59e0b" stroke-width="1.5" />
      </g>

      <!-- Traditional label -->
      <text x="0" y="155" text-anchor="middle" fill="#ef4444" font-family="'JetBrains Mono', 'Fira Code', 'SF Mono', monospace" font-size="9" font-weight="bold" letter-spacing="1.5" opacity="0.6">TRADITIONAL</text>
      <text x="0" y="170" text-anchor="middle" fill="#ef4444" font-family="'JetBrains Mono', 'Fira Code', 'SF Mono', monospace" font-size="7" opacity="0.5" letter-spacing="0.5">SEPARATED ARCHITECTURE</text>
    </g>

    <!-- ============================================ -->
    <!-- TITLE                                        -->
    <!-- ============================================ -->

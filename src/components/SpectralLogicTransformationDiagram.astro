---
// src/components/SpectralLogicTransformationDiagram.astro
---
<div class="diagram-container">
  <svg viewBox="0 0 800 350" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
    <defs>
      <filter id="glowGate" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="5" result="blur" />
        <feComposite in="SourceGraphic" in2="blur" operator="over" />
      </filter>
      
      <!-- Input 1 Gradient -->
      <linearGradient id="inTone42" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#0284c7" stop-opacity="0" />
        <stop offset="100%" stop-color="#0284c7" />
      </linearGradient>

      <!-- Input 2 Gradient -->
      <linearGradient id="inTone12" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#6d28d9" stop-opacity="0" />
        <stop offset="100%" stop-color="#6d28d9" />
      </linearGradient>

      <!-- Output Gradient -->
      <linearGradient id="outTone87" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#10b981" />
        <stop offset="100%" stop-color="#10b981" stop-opacity="0"/>
      </linearGradient>
    </defs>

    <rect width="800" height="350" fill="#0d111a" rx="12" />
    
    <text x="400" y="40" font-family="'JetBrains Mono', monospace" font-size="18" fill="#e2e8f0" font-weight="600" text-anchor="middle">SPECTRAL LOGIC TRANSFORMATION</text>
    <text x="400" y="60" font-family="'Inter', sans-serif" font-size="12" fill="#64748b" text-anchor="middle">Computation via Wavelength Conversion (No Boolean Gates)</text>

    <!-- Input 1 Connector -->
    <path d="M100,120 L300,120 C350,120 350,175 400,175" fill="none" stroke="url(#inTone42)" stroke-width="8" stroke-linecap="round" filter="url(#glowGate)" />
    <path d="M100,120 L300,120 C350,120 350,175 400,175" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" class="flow-line" />
    
    <!-- Input 2 Connector -->
    <path d="M100,230 L300,230 C350,230 350,175 400,175" fill="none" stroke="url(#inTone12)" stroke-width="8" stroke-linecap="round" filter="url(#glowGate)" />
    <path d="M100,230 L300,230 C350,230 350,175 400,175" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" class="flow-line" />
    
    <!-- Output Connector -->
    <path d="M400,175 L700,175" fill="none" stroke="url(#outTone87)" stroke-width="10" stroke-linecap="round" filter="url(#glowGate)" />
    <path d="M400,175 L700,175" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" class="flow-line output-flow" />

    <!-- Logic Gate Node (Graphene Transformation Substrate) -->
    <g transform="translate(400, 175)">
      <circle cx="0" cy="0" r="45" fill="#1e293b" stroke="#38bdf8" stroke-width="2" class="node-pulse" />
      <circle cx="0" cy="0" r="35" fill="none" stroke="#6366f1" stroke-width="1.5" stroke-dasharray="6,4" class="spin-circle" />
      <polygon points="0,-20 15,10 -15,10" fill="#e2e8f0" opacity="0.8" transform="rotate(90)" class="pulse-core" />
      
      <text x="0" y="65" font-family="'JetBrains Mono', monospace" font-size="12" fill="#94a3b8" text-anchor="middle" font-weight="bold">TRANSFORMATION</text>
      <text x="0" y="80" font-family="'Inter', sans-serif" font-size="10" fill="#64748b" text-anchor="middle">NODE</text>
    </g>

    <!-- Labels -->
    <g font-family="'JetBrains Mono', monospace" font-size="13" fill="#cbd5e1">
      <!-- Input 1 -->
      <text x="120" y="105" fill="#38bdf8">Input Signal A</text>
      <text x="120" y="145" font-family="'Inter', sans-serif" font-size="11" fill="#64748b">SpectralState_42 (λ₂, φ₁₀)</text>

      <!-- Input 2 -->
      <text x="120" y="215" fill="#a78bfa">Input Signal B</text>
      <text x="120" y="255" font-family="'Inter', sans-serif" font-size="11" fill="#64748b">SpectralState_12 (λ₀, φ₁₂)</text>

      <!-- Output -->
      <text x="550" y="155" fill="#34d399">Computed Output Y</text>
      <text x="550" y="200" font-family="'Inter', sans-serif" font-size="11" fill="#64748b">SpectralState_87 (λ₅, φ₇)</text>
    </g>

    <!-- Mathematical Model Annotation -->
    <g transform="translate(400, 310)">
      <rect x="-200" y="-15" width="400" height="30" fill="#1e293b" rx="6" opacity="0.6"/>
      <text x="0" y="4" font-family="'JetBrains Mono', monospace" font-size="12" fill="#f8fafc" text-anchor="middle">
        f_logical(SpectralState_42, SpectralState_12) = SpectralState_87
      </text>
    </g>
  </svg>
</div>

<style>
.diagram-container {
  margin: 3rem 0;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid rgba(99, 102, 241, 0.2);
  box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5);
}

.flow-line {
  stroke-dasharray: 8 16;
  opacity: 0.6;
  animation: flowAnim 1.5s linear infinite;
}

.output-flow {
  stroke-dasharray: 12 24;
  opacity: 0.8;
  animation: flowAnim 0.8s linear infinite; /* Faster simulated speed post-processing */
}

@keyframes flowAnim {
  to { stroke-dashoffset: -48; }
}

.spin-circle {
  transform-origin: center;
  animation: spin 5s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.pulse-core {
  animation: corePulse 1s ease-in-out infinite alternate;
}

@keyframes corePulse {
  0% { opacity: 0.5; fill: #38bdf8; }
  100% { opacity: 1; fill: #10b981; }
}

.node-pulse {
  animation: nodeGlow 2s ease-in-out infinite alternate;
}

@keyframes nodeGlow {
  0% { stroke: #38bdf8; box-shadow: 0 0 0 transparent; }
  100% { stroke: #10b981; filter: drop-shadow(0 0 5px #10b981); }
}
</style>

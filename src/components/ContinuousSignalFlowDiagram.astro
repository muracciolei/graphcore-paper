---
// src/components/ContinuousSignalFlowDiagram.astro
---
<div class="diagram-container">
  <svg viewBox="0 0 800 400" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
    <defs>
      <linearGradient id="gradient1" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#4B0082" />
        <stop offset="30%" stop-color="#00FFFF" />
        <stop offset="70%" stop-color="#FFFF00" />
        <stop offset="100%" stop-color="#FF0000" />
      </linearGradient>
      
      <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="4" result="blur" />
        <feComposite in="SourceGraphic" in2="blur" operator="over" />
      </filter>

      <!-- Binary Pulse Path -->
      <path id="binaryPulse" d="M100,100 L150,100 L150,50 L250,50 L250,100 L350,100 L350,50 L400,50 L400,100 L500,100 L500,50 L600,50 L600,100 L700,100" fill="none" stroke="#64748b" stroke-width="4" class="draw-binary" />
      
      <!-- Continuous Tonal Path -->
      <path id="tonalWave" d="M100,280 C200,280 150,220 250,220 C350,220 300,340 400,340 C500,340 450,250 550,250 C650,250 600,280 700,280" fill="none" stroke="url(#gradient1)" stroke-width="12" stroke-linecap="round" filter="url(#glow)" class="pulse-glow" />
    </defs>

    <rect width="800" height="400" fill="#0d111a" rx="12" />
    
    <text x="400" y="30" font-family="'JetBrains Mono', monospace" font-size="18" fill="#e2e8f0" font-weight="600" text-anchor="middle">SIGNAL PROPAGATION MODEL COMPARISON</text>

    <!-- Classical Binary Side -->
    <text x="50" y="75" font-family="'Inter', sans-serif" font-size="14" fill="#94a3b8" font-weight="bold" transform="rotate(-90 50 75)">BINARY</text>
    
    <g transform="translate(50, 20)">
      <!-- Guidelines -->
      <line x1="80" y1="50" x2="720" y2="50" stroke="#1e293b" stroke-width="1" stroke-dasharray="4,4"/>
      <line x1="80" y1="100" x2="720" y2="100" stroke="#1e293b" stroke-width="1" stroke-dasharray="4,4"/>
      
      <text x="85" y="45" font-family="'JetBrains Mono', monospace" font-size="10" fill="#64748b">1 (Voltage High)</text>
      <text x="85" y="115" font-family="'JetBrains Mono', monospace" font-size="10" fill="#64748b">0 (Voltage Zero / Discontinuity)</text>
      
      <use href="#binaryPulse" />
      
      <!-- Highlight Discontinuities -->
      <circle cx="150" cy="100" r="6" fill="none" stroke="#ef4444" stroke-width="2" class="error-ping" />
      <circle cx="250" cy="100" r="6" fill="none" stroke="#ef4444" stroke-width="2" class="error-ping" />
      <circle cx="350" cy="100" r="6" fill="none" stroke="#ef4444" stroke-width="2" class="error-ping" />
      <text x="250" y="135" font-family="'Inter', sans-serif" font-size="11" fill="#ef4444" text-anchor="middle" class="error-text">Switching gaps (latency &amp; discontinuity)</text>
    </g>

    <line x1="100" y1="170" x2="700" y2="170" stroke="#1e293b" stroke-width="2" />

    <!-- GraphCore Multi-Tonal Side -->
    <text x="50" y="280" font-family="'Inter', sans-serif" font-size="14" fill="#a78bfa" font-weight="bold" transform="rotate(-90 50 280)">GRAPHCORE</text>

    <g transform="translate(50, 0)">
      <line x1="80" y1="220" x2="720" y2="220" stroke="#1e293b" stroke-width="1" stroke-dasharray="4,4"/>
      <line x1="80" y1="280" x2="720" y2="280" stroke="#1e293b" stroke-width="1" stroke-dasharray="4,4"/>
      <line x1="80" y1="340" x2="720" y2="340" stroke="#1e293b" stroke-width="1" stroke-dasharray="4,4"/>

      <!-- Spectral Mapping text -->
      <text x="85" y="215" font-family="'JetBrains Mono', monospace" font-size="10" fill="#a78bfa">Spectral State 0 (Value 0)</text>
      <text x="85" y="275" font-family="'JetBrains Mono', monospace" font-size="10" fill="#38bdf8">Spectral State 128</text>
      <text x="85" y="335" font-family="'JetBrains Mono', monospace" font-size="10" fill="#f87171">Spectral State 255 (Value 255)</text>

      <use href="#tonalWave" />

      <!-- Annotations for continuous flow -->
      <path d="M 250 210 L 250 190 L 400 190 L 400 350 L 550 350 L 550 240" fill="none" stroke="#cbd5e1" stroke-width="1" stroke-dasharray="2,2"/>
      <text x="400" y="375" font-family="'Inter', sans-serif" font-size="12" fill="#cbd5e1" text-anchor="middle">Continuous Flow: Smooth state transitions, zero switching interruption.</text>
      <circle cx="250" cy="220" r="4" fill="#cbd5e1" />
      <text x="250" y="200" font-family="'JetBrains Mono', monospace" font-size="10" fill="#a78bfa" text-anchor="middle">Value=0</text>
      
      <circle cx="550" cy="250" r="4" fill="#cbd5e1" />
      <text x="550" y="235" font-family="'JetBrains Mono', monospace" font-size="10" fill="#facc15" text-anchor="middle">Value=192</text>
    </g>

  </svg>
</div>

<style>
.diagram-container {
  margin: 3rem 0;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid rgba(99, 102, 241, 0.2);
  box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5);
}

.draw-binary {
  stroke-dasharray: 1000;
  stroke-dashoffset: 1000;
  animation: drawLine 3.5s ease-in-out infinite;
}

@keyframes drawLine {
  0% { stroke-dashoffset: 1000; }
  40% { stroke-dashoffset: 0; }
  100% { stroke-dashoffset: 0; }
}

.pulse-glow {
  animation: waveFlow 3s ease-in-out infinite alternate;
}

@keyframes waveFlow {
  0% { filter: url(#glow) brightness(0.9); transform: translateY(-3px); }
  100% { filter: url(#glow) brightness(1.3); transform: translateY(3px); }
}

.error-ping {
  animation: ping 3.5s infinite;
  transform-origin: center;
}

@keyframes ping {
  0%, 40% { opacity: 0; transform: scale(0.5); }
  45% { opacity: 1; transform: scale(1.5); }
  50% { opacity: 0; transform: scale(2); }
  100% { opacity: 0; }
}

.error-text {
  animation: fadePulse 3.5s infinite;
}

@keyframes fadePulse {
  0%, 40% { opacity: 0; }
  45%, 80% { opacity: 1; }
  100% { opacity: 0; }
}
</style>

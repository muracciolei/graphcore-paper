---
// src/components/MultiStateToneEncodingDiagram.astro
---
<div class="diagram-container">
  <svg viewBox="0 0 800 300" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
    <defs>
      <linearGradient id="spectrumGradient" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#4B0082" />   <!-- Indigo (0) -->
        <stop offset="16%" stop-color="#0000FF" />  <!-- Blue -->
        <stop offset="33%" stop-color="#00FFFF" />  <!-- Cyan -->
        <stop offset="50%" stop-color="#00FF00" />  <!-- Green -->
        <stop offset="66%" stop-color="#FFFF00" />  <!-- Yellow -->
        <stop offset="83%" stop-color="#FF7F00" />  <!-- Orange -->
        <stop offset="100%" stop-color="#FF0000" /> <!-- Red (255) -->
      </linearGradient>
      
      <filter id="glowBlur" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="6" result="blur" />
        <feComposite in="SourceGraphic" in2="blur" operator="over" />
      </filter>
    </defs>

    <!-- Background Pattern -->
    <rect width="800" height="300" fill="#0d111a" rx="12" />
    
    <!-- Title -->
    <text x="400" y="45" font-family="'JetBrains Mono', monospace" font-size="20" fill="#cbd5e1" font-weight="600" text-anchor="middle" letter-spacing="1">MULTI-STATE PHOTONIC LOGIC ENCODING</text>
    <text x="400" y="65" font-family="'Inter', sans-serif" font-size="12" fill="#64748b" text-anchor="middle">Base-256 Spectral Matrix (16 Wavelengths &times; 16 Phase States)</text>

    <!-- Spectrum Bar -->
    <g class="spectrum-group">
      <rect x="100" y="120" width="600" height="40" fill="url(#spectrumGradient)" rx="20" filter="url(#glowBlur)" />
      <!-- Scanning Line -->
      <rect x="100" y="110" width="4" height="60" fill="#ffffff" rx="2" class="scanning-line" filter="url(#glowBlur)" />
      <rect x="100" y="110" width="2" height="60" fill="#ccffff" rx="1" class="scanning-line" />
    </g>

    <!-- Markers & Labels -->
    <g font-family="'JetBrains Mono', monospace" font-size="12" fill="#94a3b8" text-anchor="middle">
      <!-- 0 -->
      <line x1="120" y1="110" x2="120" y2="170" stroke="#cbd5e1" stroke-width="1.5" stroke-dasharray="2,2"/>
      <text x="120" y="95" fill="#a78bfa">SpectralState_0</text>
      <text x="120" y="195">Value 0</text>
      <text x="120" y="215" font-size="10" fill="#64748b">λ₀, φ₀</text>

      <!-- 64 -->
      <line x1="270" y1="110" x2="270" y2="170" stroke="#cbd5e1" stroke-width="1.5" stroke-dasharray="2,2"/>
      <text x="270" y="95" fill="#38bdf8">SpectralState_64</text>
      <text x="270" y="195">Value 64</text>
      <text x="270" y="215" font-size="10" fill="#64748b">λ₄, φ₀</text>

      <!-- 128 -->
      <line x1="400" y1="100" x2="400" y2="180" stroke="#f8fafc" stroke-width="2"/>
      <text x="400" y="85" fill="#4ade80" font-size="14" font-weight="bold">SpectralState_128</text>
      <text x="400" y="200" fill="#cbd5e1" font-weight="bold">Value 128</text>
      <text x="400" y="215" font-size="10" fill="#64748b">λ₈, φ₀</text>

      <!-- 192 -->
      <line x1="530" y1="110" x2="530" y2="170" stroke="#cbd5e1" stroke-width="1.5" stroke-dasharray="2,2"/>
      <text x="530" y="95" fill="#facc15">SpectralState_192</text>
      <text x="530" y="195">Value 192</text>
      <text x="530" y="215" font-size="10" fill="#64748b">λ₁₂, φ₀</text>

      <!-- 255 -->
      <line x1="680" y1="110" x2="680" y2="170" stroke="#cbd5e1" stroke-width="1.5" stroke-dasharray="2,2"/>
      <text x="680" y="95" fill="#f87171">SpectralState_255</text>
      <text x="680" y="195">Value 255</text>
      <text x="680" y="215" font-size="10" fill="#64748b">λ₁₅, φ₁₅</text>
    </g>

    <!-- Binary comparison text annotation -->
    <g transform="translate(400, 260)">
      <rect x="-350" y="-15" width="700" height="30" fill="#1e293b" rx="15" opacity="0.6"/>
      <text x="0" y="5" font-family="'Inter', sans-serif" font-size="12" fill="#cbd5e1" text-anchor="middle">
        <tspan fill="#f87171" font-weight="bold">NOTE:</tspan> 
        Value 0 is represented as a definitive photonic spectral state, not an absence of signal.
      </text>
    </g>
  </svg>
</div>

<style>
.diagram-container {
  margin: 3rem 0;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid rgba(99, 102, 241, 0.2);
  box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5);
}

.scanning-line {
  animation: scan 4s cubic-bezier(0.4, 0.0, 0.2, 1) infinite alternate;
  transform-origin: left;
}

@keyframes scan {
  0% { transform: translateX(0px); opacity: 0.5; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { transform: translateX(596px); opacity: 0.5; }
}

.spectrum-group {
  animation: mildPulse 3s ease-in-out infinite alternate;
}

@keyframes mildPulse {
  0% { filter: brightness(0.9); }
  100% { filter: brightness(1.2); }
}
</style>
